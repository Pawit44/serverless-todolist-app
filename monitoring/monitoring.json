{
  "title": "Todolist Application Monitoring",
  "tags": ["nodejs", "production"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "row",
      "title": "👑 Business Metrics (Application Usage)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Total Created Todos",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "targets": [{ "expr": "todo_created_total{job=\"todo-service\"}" }],
      "fieldConfig": { "defaults": { "color": { "mode": "value" }, "mappings": [] }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "textMode": "auto" }
    },
    {
      "type": "stat",
      "title": "Total Toggled Todos",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 1 },
      "targets": [{ "expr": "todo_toggled_total{job=\"todo-service\"}" }],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Total Deleted Todos",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
      "targets": [{ "expr": "todo_deleted_total{job=\"todo-service\"}" }],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "row",
      "title": "🏥 Quick Health Check",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }
    },
    {
      "type": "stat",
      "title": "Uptime (Hours)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 7 },
      "targets": [{ "expr": "(time() - process_start_time_seconds{job=\"todo-service\"}) / 3600" }],
      "fieldConfig": { "defaults": { "unit": "h", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "Open File Descriptors",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 7 },
      "targets": [{ "expr": "process_open_fds{job=\"todo-service\"}" }],
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "Active Handles (Connections)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 7 },
      "targets": [{ "expr": "nodejs_active_handles_total{job=\"todo-service\"}" }],
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "type": "row",
      "title": "💻 System Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "rate(process_cpu_seconds_total{job=\"todo-service\"}[1m]) * 100", "legendFormat": "CPU Usage" }],
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15 } } }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage (MB)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"todo-service\"} / 1024 / 1024", "legendFormat": "System RAM (RSS)" },
        { "expr": "nodejs_heap_size_used_bytes{job=\"todo-service\"} / 1024 / 1024", "legendFormat": "Node.js Heap Used" }
      ],
      "fieldConfig": { "defaults": { "unit": "megbytes", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15 } } }
    },
    {
      "type": "row",
      "title": "⚙️ Node.js Deep Dive",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },
    {
      "type": "timeseries",
      "title": "Event Loop Lag (Seconds)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "targets": [
        { "expr": "nodejs_eventloop_lag_p99_seconds{job=\"todo-service\"}", "legendFormat": "99th Percentile Lag" },
        { "expr": "nodejs_eventloop_lag_mean_seconds{job=\"todo-service\"}", "legendFormat": "Mean Lag" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries",
      "title": "Garbage Collection Rate",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "targets": [
        { "expr": "rate(nodejs_gc_duration_seconds_sum{job=\"todo-service\", kind=\"minor\"}[1m])", "legendFormat": "Minor GC" },
        { "expr": "rate(nodejs_gc_duration_seconds_sum{job=\"todo-service\", kind=\"major\"}[1m])", "legendFormat": "Major GC" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "bars", "fillOpacity": 80 } } }
    }
  ]
}